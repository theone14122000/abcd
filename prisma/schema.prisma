generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum Sector {
  HEALTH
  SALES
  MANUFACTURING
  BPO
  FINANCE
  IT
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
}

model Job {
  id          String   @id @default(cuid())
  title       String
  company     String
  location    String
  salary      String
  type        String
  description String
  sector      Sector   @default(IT)
  createdAt   DateTime @default(now())
}